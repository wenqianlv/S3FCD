# -------------------------- 深度学习训练专属忽略 --------------------------
# 1. 模型权重/训练产物（绝对不要提交，体积大且无意义）
*.pth
*.pt
*.onnx
*.h5
*.pb
checkpoints/
saved_model/
output/
results/
inference_output/

# 2. 训练日志/可视化文件
logs/
wandb/
tensorboard/
events.out.tfevents.*
*.tfevents.*
infer/
work_dirs/

# 3. 数据集（如果数据集放在项目里，不要提交；如果是单独管理的可以忽略整个data文件夹）
data/
raw_data/

# 4. 训练临时文件
*.tmp
*.bak
train_log/
eval_result/
temp/

# -------------------------- 敏感/环境配置 --------------------------
